@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
left to right direction

actor 用户 as user
actor 群主 as owner
actor "事件提供方" as provider

rectangle "监测与应变管理" {
  usecase "事件接入管理" as m1
  usecase "影响匹配分析" as m2
  usecase "风险评分预警" as m3
  usecase "持续动态分析" as m4
  usecase "自动重规划" as m5
  usecase "协同投票决策" as m6
  usecase "变更记录管理" as m7
  usecase "消息通知管理" as m8
}

user --> m2
user --> m3
user --> m6
user --> m7
user --> m8
owner --> m5
owner --> m6
provider --> m1
@enduml
