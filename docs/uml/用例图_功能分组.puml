@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
left to right direction

actor 用户 as user
actor 群主 as owner
actor 管理员 as admin
actor "事件提供方" as provider

rectangle "账号与权限管理" {
  usecase "注册/登录/注销" as a1
  usecase "忘记密码" as a2
  usecase "个人资料管理" as a3
}
rectangle "社交组队管理" {
  usecase "好友关系管理" as s1
  usecase "出行小组管理" as s2
  usecase "房间码加入" as s3
}
rectangle "出行规划管理" {
  usecase "成员约束管理" as p1
  usecase "初始方案生成" as p2
  usecase "行程节点管理" as p3
  usecase "地图路线导航" as p4
  usecase "预算费用管理" as p5
}
rectangle "监测与应变管理" {
  usecase "事件接入管理" as m1
  usecase "影响匹配分析" as m2
  usecase "风险评分预警" as m3
  usecase "持续动态分析" as m4
  usecase "自动重规划" as m5
  usecase "协同投票决策" as m6
  usecase "变更记录管理" as m7
  usecase "消息通知管理" as m8
}
rectangle "社区管理" {
  usecase "讨论区管理" as c1
  usecase "攻略社区管理" as c2
  usecase "一键套用" as c3
  usecase "行后游记生成与发布" as c4
}
rectangle "后台与监控管理" {
  usecase "用户管理" as b1
  usecase "运营后台管理" as b2
  usecase "数据统计分析" as b3
  usecase "可观测与配置" as b4
}

user --> a1
user --> a2
user --> a3
user --> s1
user --> s2
user --> s3
user --> p1
user --> p2
user --> p3
user --> p4
user --> p5
user --> m2
user --> m3
user --> m6
user --> m7
user --> m8
user --> c1
user --> c2
user --> c3
user --> c4
owner --> s2
owner --> p2
owner --> m5
owner --> m6
provider --> m1
admin --> b1
admin --> b2
admin --> b3
admin --> b4
@enduml
