@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
title 出行规划管理

start
:选择小组和出发日期;
:读取全部成员约束;
:计算可用日期交集;
if (存在日期交集?) then (是)
  :计算最低预算;
  :合并去重必访地点;
  :添加餐饮、住宿和交通节点;
  if (总成本超过最低预算?) then (是)
    :按可选优先级裁剪节点;
    :生成取舍说明;
  else (否)
    :记录预算可行;
  endif
  :生成相邻路线;
  :保存 Trip、Node、Route;
  :展示方案预览;
else (否)
  :提示成员日期无交集;
endif
stop
@enduml
