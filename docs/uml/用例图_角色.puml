@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
left to right direction

actor 游客 as guest
actor 成员 as member
actor 群主 as owner
actor 管理员 as admin
actor "外部事件源" as source

rectangle "智能旅游平台" {
  usecase "注册和登录" as auth
  usecase "注销" as logout
  usecase "管理个人资料" as profile
  usecase "管理好友关系" as friends
  usecase "创建/加入出行小组" as groups
  usecase "维护成员约束" as constraints
  usecase "生成初始方案" as initial
  usecase "查看与编辑行程" as itinerary
  usecase "接收外部事件" as events
  usecase "分析影响与风险" as risk
  usecase "生成替代方案" as replan
  usecase "参与协同投票" as vote
  usecase "查看通知与变更记录" as notices
  usecase "浏览攻略并攻略纳用" as guides
  usecase "发布讨论与行后游记" as content
  usecase "运营后台与数据统计" as operations
}

guest --> auth
member --> logout
guest --> guides
member --> profile
member --> friends
member --> groups
member --> constraints
member --> initial
member --> itinerary
member --> risk
member --> vote
member --> notices
member --> guides
member --> content
owner --> groups
owner --> initial
owner --> replan
owner --> vote
owner --> operations
source --> events
admin --> operations
admin --> profile

initial .> constraints : <<include>>
initial .> itinerary : <<include>>
risk .> events : <<include>>
replan .> risk : <<include>>
vote .> replan : <<include>>
@enduml
