@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
skinparam packageStyle rectangle
skinparam shadowing false

package "com.trip.adaptive" {
  package "controller" as controller
  package "service" as service
  package "mapper" as mapper
  package "domain/entity" as domain
  package "dto/request,response" as dto
  package "config/security" as config
  package "exception/support" as support
  package "scheduler" as scheduler
}
database "MySQL 8" as mysql
collections "Redis / Lettuce" as redis
cloud "WebSocket / STOMP" as ws

controller --> dto
controller --> service
service --> dto
service --> domain
service --> mapper
service --> support
mapper --> domain
mapper --> mysql
service --> redis
config --> service
config --> redis
config --> ws
scheduler --> service
controller --> support
@enduml
