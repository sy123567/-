@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
autonumber

actor 群主 as owner
boundary "React 前端" as web
control "PlanningController" as controller
control "PlanningService" as service
database "MySQL / MyBatis" as mysql
control "RouteService" as route

owner -> web : 选择小组与出发日期
web -> controller : POST /api/groups/{id}/trips/initial-plan
controller -> service : 校验群主权限
service -> mysql : 查询成员约束和必访地点
mysql --> service : MemberConstraint[]
service -> service : 计算日期交集、最低预算\n合并节点并裁剪可选项
service -> route : 生成相邻节点路线
route --> service : Route[]
service -> mysql : BEGIN\nINSERT trips/nodes/routes\nCOMMIT
mysql --> service : tripId
service --> controller : InitialPlanPreview
controller --> web : Result<InitialPlanPreview>
web --> owner : 显示节点、费用和取舍说明
@enduml
