@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
autonumber
title 社交组队管理

actor 成员 as user
boundary "React 前端" as web
control "GroupController" as controller
control "GroupService" as service
collections "Redis 房间码缓存" as redis
database "MySQL" as mysql
control "NotificationService" as notice

user -> web : 输入房间码
web -> controller : POST /api/groups/join
controller -> service : 校验登录用户与房间码
service -> redis : GET room:code:{code}
redis --> service : groupId
service -> mysql : 查询小组、容量和成员关系
mysql --> service : Group + count + membership
service -> mysql : INSERT group_members\nINSERT member_constraints
service -> notice : 通知群主
service --> controller : GroupDetail
controller --> web : Result<GroupDetail>
web --> user : 显示加入成功
@enduml
