@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false
autonumber

actor 管理员 as admin
boundary "React 后台" as web
control "AdminController" as controller
control "AdminStatsService" as service
database "MySQL 聚合查询" as mysql
collections "Redis 统计缓存" as redis

admin -> web : 打开统计后台
web -> controller : GET /api/admin/stats?from&to
controller -> controller : 校验 ADMIN 角色
controller -> redis : GET admin:stats:{range}
alt 命中缓存
  redis --> controller : AdminStats
else 缓存未命中
  controller -> service : 查询统计数据
  service -> mysql : 聚合 trips/events/impacts/plans
  mysql --> service : 聚合结果
  service -> redis : SET admin:stats:{range} EX
  service --> controller : AdminStats
end
controller --> web : Result<AdminStats>
web --> admin : 显示统计卡片和图表
@enduml
