@startuml
skinparam defaultFontName "WenQuanYi Zen Hei"
skinparam shadowing false

start
:打开登录页面;
:输入邮箱和密码;
:校验必填字段;
if (字段合法?) then (是)
  :查询用户;
  if (用户存在且密码正确?) then (是)
    if (账号已启用?) then (是)
      :签发 JWT;
      :写入 Redis 会话;
      :进入首页;
    else (否)
      :提示账号已停用;
    endif
  else (否)
    :提示账号或密码错误;
  endif
else (否)
  :显示表单校验信息;
endif
stop
@enduml
